# ── Supabase ────────────────────────────────────────────────────────────────
# Find these in your Supabase project: Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Settings → API → "service_role" secret. NEVER expose this in the browser.
# It is only ever read on the server. Keep it secret.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret-key

# ── Cloudflare R2 (file storage) ──────────────────────────────────────────────
# Athlete photos/videos are stored in a PRIVATE Cloudflare R2 bucket.
# R2 dashboard → Overview: the Account ID is in the right sidebar.
R2_ACCOUNT_ID=your-cloudflare-account-id
# R2 → Manage API Tokens → Create token (Object Read & Write). NEVER expose these.
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# The exact name of the bucket you created (e.g. phvc-artifacts).
R2_BUCKET=your-bucket-name

# ── Coach access ──────────────────────────────────────────────────────────────
# Comma-separated list of the Google emails allowed to log in as a coach.
# Anyone who signs in with Google but is NOT on this list is rejected.
ALLOWED_COACH_EMAILS=coach1@yourschool.org,coach2@yourschool.org

# ── Site URL (optional) ───────────────────────────────────────────────────────
# Used for OAuth redirects. Leave blank for local dev; on Vercel set it to your
# production URL, e.g. https://phvc-choiceboard.vercel.app
NEXT_PUBLIC_SITE_URL=
